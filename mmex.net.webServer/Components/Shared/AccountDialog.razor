@inject ICurrencyService CurrencyService

<MudDialog>
    <DialogContent>
        <MudTabs Elevation="0" ApplyEffectsToContainer="true" PanelClass="pa-3">
            <MudTabPanel Text="Main">
                <MudGrid>
                    <MudItem xs="12">
                        <MudTextField T="string" Label="Account Name" @bind-Value="_name" Required="true"
                            Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="6">
                        <MudSelect T="AccountType" Label="Type" @bind-Value="_type" Margin="Margin.Dense"
                            Disabled="@(Account != null)">
                            @foreach (var t in Enum.GetValues<AccountType>())
                            {
                                <MudSelectItem Value="t">@t</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="6">
                        <MudSelect T="AccountStatus" Label="Status" @bind-Value="_status" Margin="Margin.Dense">
                            @foreach (var s in Enum.GetValues<AccountStatus>())
                            {
                                <MudSelectItem Value="s">@s</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="6">
                        <MudSelect T="Currency" Label="Currency" @bind-Value="_selectedCurrency"
                            ToStringFunc="c => c?.Name ?? string.Empty" Margin="Margin.Dense">
                            @foreach (var c in Currencies)
                            {
                                <MudSelectItem Value="c">@c.Name (@c.Symbol)</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="6">
                        <MudNumericField T="decimal" Label="Initial Balance" @bind-Value="_initialBalance"
                            Format="N2" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="6">
                        <MudCheckBox T="bool" Label="Favorite" @bind-Value="_isFavorite" />
                    </MudItem>
                </MudGrid>
            </MudTabPanel>
            <MudTabPanel Text="Details">
                <MudGrid>
                    <MudItem xs="12">
                        <MudTextField T="string" Label="Account Number" @bind-Value="_accountNum" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField T="string" Label="Held At" @bind-Value="_heldAt" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField T="string" Label="Website" @bind-Value="_website" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField T="string" Label="Notes" @bind-Value="_notes" Lines="4" Margin="Margin.Dense" />
                    </MudItem>
                </MudGrid>
            </MudTabPanel>
        </MudTabs>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public Account? Account { get; set; }
    [Parameter] public IList<Currency> Currencies { get; set; } = [];

    private string? _name;
    private AccountType _type;
    private AccountStatus _status = AccountStatus.Open;
    private Currency? _selectedCurrency;
    private decimal _initialBalance;
    private bool _isFavorite;
    private string? _accountNum;
    private string? _heldAt;
    private string? _website;
    private string? _notes;

    protected override void OnInitialized()
    {
        if (Account != null)
        {
            _name = Account.Name;
            _type = Account.Type;
            _status = Account.Status;
            _selectedCurrency = Currencies.FirstOrDefault(c => c.Id == Account.CurrencyId);
            _initialBalance = Account.InitialBalance;
            _isFavorite = Account.IsFavorite;
            _accountNum = Account.AccountNum;
            _heldAt = Account.HeldAt;
            _website = Account.Website;
            _notes = Account.Notes;
        }
        else
        {
            _selectedCurrency = Currencies.FirstOrDefault();
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private void Submit()
    {
        if (string.IsNullOrWhiteSpace(_name)) return;

        var account = new Account
        {
            Name = _name!.Trim(),
            Type = _type,
            Status = _status,
            CurrencyId = _selectedCurrency?.Id ?? 1,
            InitialBalance = _initialBalance,
            IsFavorite = _isFavorite,
            AccountNum = _accountNum,
            HeldAt = _heldAt,
            Website = _website,
            Notes = _notes
        };

        MudDialog.Close(DialogResult.Ok(account));
    }
}
