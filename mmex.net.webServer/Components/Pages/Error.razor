@page "/Error"
@using System.Diagnostics

<PageTitle>Error - MoneyManager .NET</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-8">
    <MudPaper Class="pa-6" Elevation="2">
        <MudText Typo="Typo.h5" Color="Color.Error" Class="mb-4">An error occurred</MudText>
        <MudText>Sorry, something went wrong processing your request.</MudText>
        <MudButton Href="/" Variant="Variant.Filled" Color="Color.Primary" Class="mt-4">Back to Dashboard</MudButton>
    </MudPaper>
</MudContainer>
