@page "/"
@inject IAccountService AccountService
@inject ICurrencyService CurrencyService

<PageTitle>Dashboard - MoneyManager .NET</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4">Dashboard</MudText>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudGrid>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4 stat-card" Elevation="2">
                <MudText Typo="Typo.caption" Color="Color.Secondary">Total Accounts</MudText>
                <MudText Typo="Typo.h4">@_accounts.Count</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4 stat-card" Elevation="2">
                <MudText Typo="Typo.caption" Color="Color.Secondary">Net Worth</MudText>
                <MudText Typo="Typo.h4" Class="@(_totalBalance >= 0 ? "amount-positive" : "amount-negative")">
                    @_totalBalance.ToString("N2")
                </MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="pa-4 stat-card" Elevation="2">
                <MudText Typo="Typo.caption" Color="Color.Secondary">Base Currency</MudText>
                <MudText Typo="Typo.h4">@(_baseCurrency?.Symbol ?? "—")</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudText Typo="Typo.h6" Class="mt-6 mb-3">Account Balances</MudText>

    <MudGrid>
        @foreach (var group in _accounts.GroupBy(a => a.Type).OrderBy(g => g.Key))
        {
            <MudItem xs="12" md="6">
                <MudPaper Elevation="1" Class="pa-3">
                    <MudText Typo="Typo.subtitle1" Class="mb-2">
                        <MudIcon Icon="@GetAccountIcon(group.Key)" Size="Size.Small" Class="mr-1" />
                        @group.Key
                    </MudText>
                    <MudSimpleTable Dense="true" Hover="true">
                        <thead>
                            <tr><th>Account</th><th style="text-align:right">Balance</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var acct in group)
                            {
                                var bal = _balances.GetValueOrDefault(acct.Id);
                                <tr style="cursor:pointer" @onclick="() => NavigateToAccount(acct.Id)">
                                    <td>
                                        @acct.Name
                                        @if (acct.IsFavorite)
                                        {
                                            <MudIcon Icon="@Icons.Material.Filled.Star" Size="Size.Small" Color="Color.Warning" />
                                        }
                                    </td>
                                    <td style="text-align:right" class="@(bal >= 0 ? "amount-positive" : "amount-negative")">
                                        @bal.ToString("N2") @(acct.Currency?.Symbol)
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </MudSimpleTable>
                </MudPaper>
            </MudItem>
        }
    </MudGrid>
}

@code {
    [Inject] private NavigationManager Nav { get; set; } = default!;

    private bool _loading = true;
    private IList<Account> _accounts = [];
    private Dictionary<long, decimal> _balances = new();
    private decimal _totalBalance;
    private Currency? _baseCurrency;

    protected override async Task OnInitializedAsync()
    {
        _accounts = await AccountService.GetAllOpenAsync();
        _baseCurrency = await CurrencyService.GetBaseCurrencyAsync();

        foreach (var acct in _accounts)
        {
            var bal = await AccountService.GetBalanceAsync(acct.Id);
            _balances[acct.Id] = bal;
        }

        _totalBalance = _balances.Values.Sum();
        _loading = false;
    }

    private void NavigateToAccount(long accountId) => Nav.NavigateTo($"/accounts/{accountId}");

    private static string GetAccountIcon(AccountType type) => type switch
    {
        AccountType.Cash => Icons.Material.Filled.Money,
        AccountType.Checking => Icons.Material.Filled.AccountBalance,
        AccountType.CreditCard => Icons.Material.Filled.CreditCard,
        AccountType.Investment or AccountType.Shares => Icons.Material.Filled.TrendingUp,
        AccountType.Term => Icons.Material.Filled.Savings,
        AccountType.Loan => Icons.Material.Filled.RequestPage,
        AccountType.Asset => Icons.Material.Filled.Home,
        _ => Icons.Material.Filled.AccountBalanceWallet
    };
}
